---
import BaseLayout from './BaseLayout.astro';
import { img, cloudinarySrcset } from '../utils/cloudinary';
import { SITE }   from '../config/site';

interface Props {
  title:         string;
  date:          Date;
  dateModified?: Date;
  excerpt:       string;
  cover:         string;
}

const { title, date, dateModified, excerpt, cover } = Astro.props;

const dateStr = date.toLocaleDateString('pl-PL', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const jsonLd = {
  '@context':    'https://schema.org',
  '@type':       'BlogPosting',
  headline:      title,
  description:   excerpt,
  image:         img.postCover(cover),
  datePublished: date.toISOString(),
  dateModified:  (dateModified ?? date).toISOString(),
  author: {
    '@type': 'Person',
    name:    'Maciej Rafalski',
    url:     `${SITE.finalUrl}/about`,
  },
  publisher: {
    '@type': 'Organization',
    name:    SITE.name,
    logo: {
      '@type': 'ImageObject',
      url:     `${SITE.finalUrl}/favicons/web-app-manifest-512x512.png`,
    },
  },
};
---

<BaseLayout
  title={title}
  description={excerpt}
  ogImage={img.og(cover)}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto">

        <header class="mb-8">
          <time
            datetime={date.toISOString()}
            class="text-sm text-glass-muted"
          >
            {dateStr}
          </time>
          <h1 class="mt-2 text-gradient font-heading text-[clamp(1.75rem,4vw,3rem)] font-medium leading-tight">
            {title}
          </h1>
          <p class="mt-4 text-lg text-glass-muted">
            {excerpt}
          </p>
        </header>

        {cover && (
          <figure class="mb-12">
            <div class="img-wrapper">
              <picture>
                <source
                  media="(max-width: 640px)"
                  srcset={cloudinarySrcset(cover, [400, 640], { aspectRatio: '1:1', crop: 'fill' })}
                  sizes="100vw"
                />
                <source
                  media="(min-width: 641px)"
                  srcset={cloudinarySrcset(cover, [768, 1200], { aspectRatio: '16:9', crop: 'fill' })}
                  sizes="768px"
                />
                <img
                  src={img.postCover(cover)}
                  alt={title}
                  width="1200"
                  height="675"
                  loading="eager"
                  decoding="async"
                  class="w-full h-auto rounded-xl"
                />
              </picture>
            </div>
          </figure>
        )}

        <div class="prose">
          <slot />
        </div>

      </div>
    </div>
  </article>
</BaseLayout>