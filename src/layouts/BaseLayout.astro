---
import '../styles/global.css';
import BaseHead  from '../components/BaseHead.astro';
import Header    from '../components/Header.astro';
import Footer    from '../components/Footer.astro';
import GTranslate from '../components/GTranslate.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { ANALYTICS } from '../config/site';

const isProd = import.meta.env.PROD;

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
  ogType?:      'website' | 'article';
  canonical?:   string;
  noindex?:     boolean;
  jsonLd?:      object | object[];
}

const props = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <BaseHead {...props} />

{isProd && (
  <script is:inline define:vars={{ gtmId: ANALYTICS.gtmId }}>
    function loadGTM(id) {
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',id);
    }

    window.addEventListener('cc:onConsent', function(e) {
      if (e.detail.cookie.categories.includes('analytics')) {
        loadGTM(gtmId);
      }
    });

    // Jeśli zgoda była już wcześniej udzielona
    window.addEventListener('cc:onChange', function(e) {
      if (e.detail.cookie.categories.includes('analytics')) {
        loadGTM(gtmId);
      }
    });
  </script>
)}
  </head>
  <body class="antialiased min-h-screen flex flex-col">

{isProd && (
<!-- Google Tag Manager (noscript) -->
<noscript>
  <iframe
    src={`https://www.googletagmanager.com/ns.html?id=${ANALYTICS.gtmId}`}
    height="0" width="0"
    style="display:none;visibility:hidden"
  ></iframe>
</noscript>
)}

    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-glass-accent-amber focus:text-glass-black focus:rounded-lg focus:font-semibold">
      Przejdź do treści
    </a>

    <Header />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
    <CookieConsent />
    <GTranslate />

  </body>
</html>