---
import { NAV, NAV_CTA, SITE, MEDIA, withBase } from '../config/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/' || currentPath === '/mrglassproject-com/';
  return currentPath.startsWith(href);
};
---

<header x-data="{ open: false }">
  <div class="container px-4 mx-auto">
    <nav class="flex justify-between items-center py-8">

      <a href="/" aria-label={SITE.fullName} class="flex items-center">
        <img
          src={withBase(MEDIA.logo.src)}
          alt={MEDIA.logo.alt}
          width={MEDIA.logo.navWidth}
          height={MEDIA.logo.navHeight}
          class="w-32 h-auto"
          loading="eager"
          decoding="async"
        />
      </a>

      <ul class="hidden lg:flex ml-auto mr-8 items-center space-x-8 list-none">
        {NAV.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm font-medium transition-colors duration-200',
                isActive(href)
                  ? 'text-glass-white'
                  : 'text-glass-muted hover:text-glass-white'
              ]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href={NAV_CTA.href}
        class="hidden lg:block px-6 py-3 text-sm font-semibold text-glass-black bg-glass-accent-amber hover:bg-glass-accent-glow rounded-full transition-all duration-200 hover:shadow-lg"
        aria-label={`${NAV_CTA.label} — zarezerwuj miejsce`}
      >
        {NAV_CTA.label}
      </a>

      <button
        class="lg:hidden block text-glass-muted hover:text-glass-white focus:outline-none transition-colors duration-200"
        x-on:click="open = !open"
        x-bind:aria-expanded="open.toString()"
        aria-controls="mobile-menu-panel"
        aria-label="Otwórz menu"
      >
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"/>
        </svg>
      </button>

    </nav>
  </div>

  {/* Overlay */}
  <div
    x-show="open"
    x-on:click="open = false"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-glass-black/80 z-40"
    aria-hidden="true"
  ></div>

  {/* Menu mobilne */}
  <nav
    id="mobile-menu-panel"
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-x-4"
    x-transition:enter-end="opacity-100 translate-x-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-x-0"
    x-transition:leave-end="opacity-0 -translate-x-4"
    class="fixed top-0 left-0 bottom-0 w-5/6 max-w-sm z-50 flex flex-col py-6 px-6 bg-glass-anthracite border-r border-glass-border overflow-y-auto"
    aria-label="Nawigacja mobilna"
  >
    <div class="flex items-center justify-between mb-12">
      <a href="/" aria-label={SITE.fullName}>
        <img
          src={withBase(MEDIA.logo.src)}
          alt={MEDIA.logo.alt}
          width={MEDIA.logo.navWidth}
          height={MEDIA.logo.navHeight}
          class="w-32 h-auto"
          loading="lazy"
          decoding="async"
        />
      </a>
      <button
        x-on:click="open = false"
        aria-label="Zamknij menu"
        class="text-glass-muted hover:text-glass-white transition-colors duration-200"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <ul class="list-none p-0 m-0">
      {NAV.map(({ label, href }) => (
        <li class="mb-1">
          <a
            href={href}
            class:list={[
              'block p-4 text-sm font-semibold rounded-lg transition-all duration-200',
              isActive(href)
                ? 'text-glass-white bg-glass-black'
                : 'text-glass-muted hover:text-glass-white hover:bg-glass-black'
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
            x-on:click="open = false"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-auto pt-6">
      <a
        href={NAV_CTA.href}
        class="inline-block px-6 py-3 text-sm text-center font-semibold text-glass-black bg-glass-accent-amber hover:bg-glass-accent-glow rounded-full transition-all duration-200"
        x-on:click="open = false"
      >
        {NAV_CTA.label}
      </a>
    </div>
  </nav>

</header>
