---
import { CONTACT } from '../../config/site';

interface Props {
  title?:      string;
  description?: string;
  ctaLabel?:   string;
  ctaHref?:    string;
}

const {
  title       = 'Masz projekt, przestrzeń lub pomysł? Porozmawiajmy.',
  description = 'Jeśli masz pomysł lub potrzebujesz konsultacji dotyczącej szkła, zapraszam do kontaktu. Wspólnie określimy możliwości i zakres realizacji, dopasowując projekt do Twoich potrzeb i przestrzeni. Odpowiadamy na zapytania w ciągu 24 godzin w dni robocze.',
  ctaLabel    = 'Opisz swój projekt',
  ctaHref     = '/contact',
} = Astro.props;
---

<section class="py-20 lg:py-28">
  <div class="container px-4 mx-auto">
    <div class="max-w-xl lg:max-w-3xl mx-auto text-center">

      <h2 class="mb-8 mt-4 text-3xl md:text-4xl lg:text-5xl font-medium text-gradient font-heading">
        {title}
      </h2>

      <p class="text-lg leading-relaxed text-glass-muted mb-8">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-glass-black bg-glass-white hover:bg-glass-white/90 rounded-full transition-all duration-200 hover:shadow-lg group"
        >
          {ctaLabel}
          <svg class="ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href={CONTACT.phoneHref}
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-glass-white border border-glass-border hover:border-white/50 rounded-full transition-all duration-200"
        >
          Zadzwoń {CONTACT.phone}
        </a>
      </div>

    </div>
  </div>
</section>