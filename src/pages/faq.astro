---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionCta from '../components/ui/SectionCta.astro';

const faqs = await getCollection('faq');
const sorted = faqs.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="FAQ - Najczęściej zadawane pytania | Glass Project"
  description="Odpowiedzi na najczęstsze pytania dotyczące zamówień, wyceny, realizacji i współpracy z pracownią szkła artystycznego Glass Project."
>

  <section class="section-py">
    <div class="container px-4 mx-auto">

      <div class="mb-12 text-center">
        <h1 class="mt-2 section-heading">FAQ - Najczęściej zadawane pytania</h1>
      </div>

      <div class="relative max-w-4xl mx-auto">

        <div class="absolute inset-0 bg-glass-accent-fire opacity-10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

        <ul class="relative space-y-4">
          {sorted.map((faq, i) => (
            <li class="p-1 border border-white/20 hover:border-white/30 rounded-2xl transition-all duration-200">
              <div
                class="px-6 py-8 bg-gradient-to-t from-glass-anthracite to-glass-accent-fire/10 border border-white/20 hover:border-white/30 rounded-xl transition-all duration-200"
                x-data={`{ open: ${i === 0} }`}
              >
                <button
                  class="group w-full flex justify-between items-center text-left"
                  x-on:click="open = !open"
                  x-bind:aria-expanded="open.toString()"
                >
                  <h2 class="text-lg font-medium text-gradient font-heading group-hover:opacity-90 transition-opacity duration-200 pr-4">
                    {faq.data.question}
                  </h2>
                  <span
                    class="flex-shrink-0 inline-block transform transition-transform duration-200"
                    x-bind:class="open ? 'rotate-180' : 'rotate-0'"
                    aria-hidden="true"
                  >
                    <svg class="w-4 h-4 text-glass-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </span>
                </button>

                <div
                  x-ref="container"
                  x-show="open"
                  x-transition:enter="transition ease-out duration-300"
                  x-transition:enter-start="opacity-0 -translate-y-2"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-200"
                  x-transition:leave-start="opacity-100 translate-y-0"
                  x-transition:leave-end="opacity-0 -translate-y-2"
                >
                  <p class="prose-p mt-4 max-w-2xl" set:html={faq.data.answer.replace(/\n/g, '<br/>')} />
                </div>
              </div>
            </li>
          ))}
        </ul>

      </div>
    </div>
  </section>

  <SectionCta
    title="Nie znalazłeś odpowiedzi? Napisz lub zadzwoń!"
    description="Każde zapytanie traktujemy tak samo — niezależnie czy chodzi o wazon, instalację w hotelu czy prezent na rocznicę. Odpowiadamy w ciągu 24h w dni robocze."
    ctaLabel="Napisz do nas"
    ctaHref="/contact"
  />

</BaseLayout>