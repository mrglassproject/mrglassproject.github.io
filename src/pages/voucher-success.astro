---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allFaq = await getCollection('voucherfaq');
const faqs = allFaq.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="Dziękujemy za zakup vouchera"
  description="Dziękujemy za zakup vouchera na warsztaty szkła artystycznego MR Glass Project."
  noindex={true}
>

  {/* ── Sekcja 1 — Potwierdzenie ────────────────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-2xl mx-auto text-center">
        <div class="w-16 h-16 mx-auto mb-8 flex items-center justify-center rounded-full border border-green-500/50 bg-green-500/10">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-green-500" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>

        <h1 class="section-heading">Dziękujemy za zakup vouchera</h1>

        <p class="prose-p">
          W osobnej wiadomości e-mail otrzymasz swój voucher. Poniżej masz odpowiedzi na najczęściej zadawane pytania.
        </p>
      </div>
    </div>
  </section>

  {/* ── Sekcja 2 — FAQ ──────────────────────────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-4xl mx-auto">
        <h2 class="mb-16 text-center section-heading">Najczęściej zadawane pytania</h2>

        <div
          x-data={`{
            faqs: ${JSON.stringify(faqs.map((f, i) => ({ i, question: f.data.question, answer: f.data.answer })))}
          }`}
        >
          <ul class="space-y-4">
            <template x-for="faq in faqs" x-bind:key="faq.i">
              <li class="p-1 border border-white/20 hover:border-white/30 rounded-2xl transition-all duration-200">
                <div
                  class="px-6 py-6 bg-gradient-to-t from-glass-anthracite to-glass-accent-fire/10 border border-white/10 rounded-xl"
                  x-data="{ isOpen: false }"
                >
                  <button
                    class="group w-full flex justify-between items-center text-left"
                    x-on:click="isOpen = !isOpen"
                    x-bind:aria-expanded="isOpen.toString()"
                  >
                    <h3 class="text-lg font-medium text-gradient font-heading pr-4" x-text="faq.question"></h3>
                    <span
                      class="flex-shrink-0 transform transition-transform duration-200"
                      x-bind:class="isOpen ? 'rotate-180' : 'rotate-0'"
                      aria-hidden="true"
                    >
                      <svg class="w-4 h-4 text-glass-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </span>
                  </button>

                  <div
                    x-show="isOpen"
                    x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 -translate-y-2"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-200"
                    x-transition:leave-start="opacity-100 translate-y-0"
                    x-transition:leave-end="opacity-0 -translate-y-2"
                  >
                    <p class="prose-p mt-4 max-w-2xl" x-text="faq.answer"></p>
                  </div>
                </div>
              </li>
            </template>
          </ul>
        </div>

        <p class="mt-12 text-center text-glass-muted">
          Masz inne pytanie?
          <a href="/contact" class="text-glass-accent-amber hover:text-glass-accent-glow transition-colors duration-200 ml-1">Napisz do nas →</a>
        </p>
      </div>
    </div>
  </section>

</BaseLayout>