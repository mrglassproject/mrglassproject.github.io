---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBrands from '../components/ui/SectionBrands.astro';
import SectionCta from '../components/ui/SectionCta.astro';
import { cloudinaryUrl, cloudinarySrcset } from '../utils/cloudinary';
import settings from '../data/settings.json';

const allProjects = await getCollection('projects');

const firmaProjects = (settings.ofertaFirmy ?? [])
  .map((slug: string) => allProjects.find(p => p.id === slug))
  .filter(Boolean)
  .slice(0, 5);

const domProjects = (settings.ofertaDom ?? [])
  .map((slug: string) => allProjects.find(p => p.id === slug))
  .filter(Boolean)
  .slice(0, 5);

// Zdjęcia na sztywno dla sekcji intro
const FOTO_FIRMA = 'maciej-rafalski-glass-project-warszawa-fot-home-prace-fot-1';
const FOTO_DOM   = 'maciej-rafalski-glass-project-warszawa-fot-home-prace-fot-3';

const steps = [
  { nr: 1, text: 'Opisujesz przestrzeń, cel i budżet. Możemy spotkać się w pracowni lub porozmawiać zdalnie. Bez zobowiązań.' },
  { nr: 2, text: 'Przygotowujemy propozycję formy, materiału i skali. Dostarczamy szkic koncepcyjny i wycenę w ciągu 5–7 dni roboczych.' },
  { nr: 3, text: 'Każdy obiekt powstaje ręcznie w pracowni. Czas realizacji zależy od skali projektu — informujemy o nim na etapie wyceny.' },
  { nr: 4, text: 'Dostarczamy gotowy element wraz z dokumentacją techniczną. W przypadku instalacji — koordynujemy montaż na miejscu.' },
];

function getMasonryLayout(projects: typeof firmaProjects) {
  return {
    left:   [projects[0], projects[1]],
    center: projects[2],
    right:  [projects[3], projects[4]],
  };
}

const firmaLayout = getMasonryLayout(firmaProjects);
const domLayout   = getMasonryLayout(domProjects);
---

<BaseLayout
  title="Oferta — Szklane obiekty na zamówienie | MR Glass Project"
  description="Projekty szklane na zamówienie dla firm, hoteli, architektów i klientów prywatnych. Pracownia szkła artystycznego Maciej Rafalski, Warszawa."
>

  {/* ── Sekcja 1 — Dla firm ─────────────────────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="flex flex-wrap items-center -mx-4">

        <div class="w-full lg:w-1/2 px-4 mb-16 lg:mb-0 lg:order-last">
          <div class="p-1 border border-glass-border rounded-2xl">
            <picture>
              <source
                media="(max-width: 640px)"
                srcset={cloudinarySrcset(FOTO_FIRMA, [400, 640], { aspectRatio: '1:1', crop: 'fill', gravity: 'auto' })}
                sizes="100vw"
              />
              <source
                media="(min-width: 641px)"
                srcset={cloudinarySrcset(FOTO_FIRMA, [400, 600, 720], { aspectRatio: '9:16', crop: 'fill', gravity: 'auto' })}
                sizes="50vw"
              />
              <img
                src={cloudinaryUrl(FOTO_FIRMA, { width: 720, aspectRatio: '9:16', crop: 'fill', gravity: 'auto' })}
                alt="Szklany obiekt artystyczny — realizacja dla przestrzeni komercyjnej"
                width="720" height="1280"
                class="w-full h-auto object-cover rounded-xl"
                loading="eager"
                decoding="async"
              />
            </picture>
          </div>
        </div>

        <div class="w-full lg:w-1/2 px-4">
          <h1 class="mb-8 section-heading">Projekty na zamówienie dla firm, hoteli i architektów</h1>
          <p class="prose-p">Od 2005 roku realizujemy szklane obiekty, które stają się częścią architektury, identyfikacji wizualnej i przestrzeni komercyjnych. Każda realizacja powstaje tu, w pracowni na Ochocie, ręcznie - od pierwszego szkicu do gotowego elementu.</p>

          <ul class="space-y-8">
            {[
              { title: 'Wykonujemy realizacje dla hoteli, biur i przestrzeni usługowych', desc: 'Tworzymy obiekty dekoracyjne, elementy świetlne oraz formy dedykowane recepcjom, lobby, restauracjom i przestrzeniom eventowym.' },
              { title: 'Tworzymy elementy identyfikacji wizualnej i projekty specjalne', desc: 'Realizujemy obiekty okolicznościowe, formy dedykowane - takie jak nagrody czy statuetki - oraz projekty, w których szkło staje się elementem kampanii wizerunkowych.' },
              { title: 'Produkujemy elementy przestrzenne i architektoniczne', desc: 'Wytwarzamy szklane formy, które stają się integralną częścią architektury - od rzeźb i instalacji artystycznych, przez dekoracyjne panele i moduły ścienne z reliefem, po podświetlane sufity oraz elementy fasad i witryn.' },
            ].map(({ title, desc }) => (
              <li class="flex gap-4">
                <div class="flex-shrink-0 mt-1 text-glass-white">
                  <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <h2 class="mb-1 text-xl md:text-2xl font-medium text-gradient font-body">{title}</h2>
                  <p class="prose-p">{desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  {/* ── Sekcja 2 — Galeria dla firm ─────────────────────────────── */}
  {firmaProjects.length === 5 && (
    <section class="section-py">
      <div class="container mx-auto px-4">
        <h2 class="mb-12 text-center section-heading">Przykładowe realizacje do wnętrz komercyjnych</h2>

        <div
          class="flex flex-wrap -m-4"
          x-data="{ lightbox: false, current: '', currentAlt: '', open(src, alt) { this.current = src; this.currentAlt = alt; this.lightbox = true; }, close() { this.lightbox = false; } }"
        >
          <div class="w-full lg:w-1/4 p-4 flex flex-col gap-4">
            {firmaLayout.left.map((p, i) => (
              <button
                class="block overflow-hidden rounded-2xl border border-glass-border group cursor-zoom-in"
                x-on:click={`open('${cloudinaryUrl(p.data.images[0], { width: 900, crop: 'fill' })}', '${p.data.title}')`}
                aria-label={`Powiększ: ${p.data.title}`}
              >
                <img
                  src={cloudinaryUrl(p.data.images[0], { width: 400, aspectRatio: i === 0 ? '4:5' : '4:3', crop: 'fill' })}
                  alt={p.data.title}
                  class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </button>
            ))}
          </div>

          <div class="w-full lg:w-1/2 p-4">
            <button
              class="block w-full h-full overflow-hidden rounded-2xl border border-glass-border group cursor-zoom-in"
              x-on:click={`open('${cloudinaryUrl(firmaLayout.center.data.images[0], { width: 1200, crop: 'fill' })}', '${firmaLayout.center.data.title}')`}
              aria-label={`Powiększ: ${firmaLayout.center.data.title}`}
            >
              <img
                src={cloudinaryUrl(firmaLayout.center.data.images[0], { width: 800, aspectRatio: '1:1', crop: 'fill' })}
                alt={firmaLayout.center.data.title}
                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </button>
          </div>

          <div class="w-full lg:w-1/4 p-4 flex flex-col gap-4">
            {firmaLayout.right.map((p) => (
              <button
                class="block overflow-hidden rounded-2xl border border-glass-border group cursor-zoom-in"
                x-on:click={`open('${cloudinaryUrl(p.data.images[0], { width: 900, crop: 'fill' })}', '${p.data.title}')`}
                aria-label={`Powiększ: ${p.data.title}`}
              >
                <img
                  src={cloudinaryUrl(p.data.images[0], { width: 400, aspectRatio: '1:1', crop: 'fill' })}
                  alt={p.data.title}
                  class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </button>
            ))}
          </div>

          <div
            x-show="lightbox"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 z-50 flex items-center justify-center bg-glass-black/95 p-4"
            x-on:click.self="close()"
            x-on:keydown.escape.window="close()"
            role="dialog"
            aria-modal="true"
          >
            <button class="absolute top-4 right-4 text-glass-muted hover:text-glass-white transition-colors duration-200" x-on:click="close()" aria-label="Zamknij">
              <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
            <img x-bind:src="current" x-bind:alt="currentAlt" class="max-w-full max-h-[90vh] rounded-xl object-contain"/>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ── Sekcja 3 — CTA dla firm ─────────────────────────────────── */}
  <SectionCta
    title="Realizujemy projekty dla firm, hoteli i architektów"
    description="Hotele, restauracje, biura, przestrzenie eventowe. Każda realizacja powstaje w pracowni od podstaw - ręcznie, według Twoich wymagań i w skali, której potrzebujesz."
    ctaLabel="Opisz nam swój projekt"
  />

  {/* ── Sekcja 4 — Brands ───────────────────────────────────────── */}
  <SectionBrands />

  {/* ── Sekcja 5 — Jak wygląda współpraca ──────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <h2 class="mb-12 text-center section-heading">Jak wygląda współpraca?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto">
        {steps.map(({ nr, text }) => (
          <div>
            <span class="mb-4 flex items-center justify-center w-12 h-12 rounded-full bg-glass-white text-glass-black font-medium text-xl">
              {nr}
            </span>
            <p class="prose-p">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── Sekcja 6 — Dla domu ─────────────────────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="flex flex-wrap items-center -mx-4">

        <div class="w-full lg:w-1/2 px-4 mb-16 lg:mb-0 lg:order-last">
          <div class="p-1 border border-glass-border rounded-2xl">
            <picture>
              <source
                media="(max-width: 640px)"
                srcset={cloudinarySrcset(FOTO_DOM, [400, 640], { aspectRatio: '1:1', crop: 'fill', gravity: 'auto' })}
                sizes="100vw"
              />
              <source
                media="(min-width: 641px)"
                srcset={cloudinarySrcset(FOTO_DOM, [400, 600, 720], { aspectRatio: '9:16', crop: 'fill', gravity: 'auto' })}
                sizes="50vw"
              />
              <img
                src={cloudinaryUrl(FOTO_DOM, { width: 720, aspectRatio: '9:16', crop: 'fill', gravity: 'auto' })}
                alt="Szklany obiekt artystyczny — realizacja dla przestrzeni prywatnej"
                width="720" height="1280"
                class="w-full h-auto object-cover rounded-xl"
                loading="lazy"
                decoding="async"
              />
            </picture>
          </div>
        </div>

        <div class="w-full lg:w-1/2 px-4">
          <h2 class="mb-8 section-heading">Projekty na zamówienie dla domu</h2>
          <p class="prose-p">To projekty, które tworzę z myślą o prywatnych wnętrzach i indywidualnych potrzebach. Pracuję nad formami, które podkreślają charakter domu, wprowadzają do niego unikatowy akcent i pozwalają zamienić osobiste pomysły w szklane obiekty o trwałej wartości.</p>

          <ul class="space-y-8">
            {[
              { title: 'Formy dekoracyjne', desc: 'Realizujemy szklane obiekty artystyczne dopasowane do estetyki wnętrza: rzeźby, dekoracje ścienne, misy, elementy przestrzenne i formy barwione lub strukturalne, które nadają przestrzeni indywidualny wyraz.' },
              { title: 'Szkło użytkowe', desc: 'Tworzymy przedmioty łączące funkcję z estetyką: naczynia, patery, wazony, oświetlenie czy detale meblowe. Każdy element powstaje ręcznie, dzięki czemu wnosi do wnętrza unikatowy charakter.' },
              { title: 'Prezenty indywidualne i obiekty do wystroju wnętrz', desc: 'Przygotowujemy personalizowane upominki oraz projekty dedykowane konkretnym przestrzeniom: szklane akcenty, elementy dekoracyjne, instalacje świetlne czy detale architektoniczne tworzone specjalnie dla danego domu.' },
            ].map(({ title, desc }) => (
              <li class="flex gap-4">
                <div class="flex-shrink-0 mt-1 text-glass-white">
                  <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="mb-1 text-xl md:text-2xl font-medium text-gradient font-body">{title}</h3>
                  <p class="prose-p">{desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  {/* ── Sekcja 7 — Galeria dla domu ─────────────────────────────── */}
  {domProjects.length === 5 && (
    <section class="section-py">
      <div class="container mx-auto px-4">
        <h2 class="mb-12 text-center section-heading">Przykładowe realizacje dla osób prywatnych</h2>

        <div
          class="flex flex-wrap -m-4"
          x-data="{ lightbox: false, current: '', currentAlt: '', open(src, alt) { this.current = src; this.currentAlt = alt; this.lightbox = true; }, close() { this.lightbox = false; } }"
        >
          <div class="w-full lg:w-1/4 p-4 flex flex-col gap-4">
            {domLayout.left.map((p, i) => (
              <button
                class="block overflow-hidden rounded-2xl border border-glass-border group cursor-zoom-in"
                x-on:click={`open('${cloudinaryUrl(p.data.images[0], { width: 900, crop: 'fill' })}', '${p.data.title}')`}
                aria-label={`Powiększ: ${p.data.title}`}
              >
                <img
                  src={cloudinaryUrl(p.data.images[0], { width: 400, aspectRatio: i === 0 ? '4:5' : '4:3', crop: 'fill' })}
                  alt={p.data.title}
                  class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </button>
            ))}
          </div>

          <div class="w-full lg:w-1/2 p-4">
            <button
              class="block w-full h-full overflow-hidden rounded-2xl border border-glass-border group cursor-zoom-in"
              x-on:click={`open('${cloudinaryUrl(domLayout.center.data.images[0], { width: 1200, crop: 'fill' })}', '${domLayout.center.data.title}')`}
              aria-label={`Powiększ: ${domLayout.center.data.title}`}
            >
              <img
                src={cloudinaryUrl(domLayout.center.data.images[0], { width: 800, aspectRatio: '1:1', crop: 'fill' })}
                alt={domLayout.center.data.title}
                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </button>
          </div>

          <div class="w-full lg:w-1/4 p-4 flex flex-col gap-4">
            {domLayout.right.map((p) => (
              <button
                class="block overflow-hidden rounded-2xl border border-glass-border group cursor-zoom-in"
                x-on:click={`open('${cloudinaryUrl(p.data.images[0], { width: 900, crop: 'fill' })}', '${p.data.title}')`}
                aria-label={`Powiększ: ${p.data.title}`}
              >
                <img
                  src={cloudinaryUrl(p.data.images[0], { width: 400, aspectRatio: '1:1', crop: 'fill' })}
                  alt={p.data.title}
                  class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </button>
            ))}
          </div>

          <div
            x-show="lightbox"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 z-50 flex items-center justify-center bg-glass-black/95 p-4"
            x-on:click.self="close()"
            x-on:keydown.escape.window="close()"
            role="dialog"
            aria-modal="true"
          >
            <button class="absolute top-4 right-4 text-glass-muted hover:text-glass-white transition-colors duration-200" x-on:click="close()" aria-label="Zamknij">
              <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
            <img x-bind:src="current" x-bind:alt="currentAlt" class="max-w-full max-h-[90vh] rounded-xl object-contain"/>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* ── CTA końcowe ─────────────────────────────────────────────── */}
  <SectionCta />

</BaseLayout>