---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT } from '../config/site';

const allWorkshops = await getCollection('workshops');
const workshops = allWorkshops
  .filter(w => w.data.active)
  .sort((a, b) => a.data.order - b.data.order);

const allFaq = await getCollection('voucherfaq');
const faqs = allFaq.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="Vouchery na warsztaty szkła dmuchanego i fusingu"
  description="Warsztaty szkła artystycznego w Warszawie: dmuchanie szkła i fusing w małych grupach. Poznaj terminy, program i zarezerwuj miejsce w pracowni."
>

  {/* ── Sekcja 1 — Hero ─────────────────────────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-2xl mx-auto text-center mb-16">
        <h1 class="section-heading">Vouchery na warsztaty</h1>
        <p class="prose-p">
          Szukasz oryginalnego prezentu dla bliskiej osoby? Podaruj jej voucher na wybrane warsztaty ze szkła dmuchanego lub fusingu. 
        </p>
      </div>

      {/* ── Karty voucherów ─────────────────────────────────────── */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {workshops.map((w, i) => {
          const hasPair = !!w.data.pricePair && w.data.voucherPair !== false;
          const featured = i === 0;
          return (
            <>
              {/* Voucher 1 osoba */}
              <div class="relative p-1 border border-white/20 hover:border-white/30 rounded-2xl transition-all duration-200 h-full">
                <div class="absolute inset-0 bg-glass-accent-fire opacity-10 rounded-2xl blur-3xl pointer-events-none" aria-hidden="true"></div>
                <div class="relative bg-gradient-to-t from-glass-anthracite to-glass-accent-fire/10 border border-white/10 rounded-xl px-8 lg:px-10 pb-10 pt-8 h-full flex flex-col">

                  <div class="mb-2">
                    <span class="badge badge-amber">1 osoba</span>
                  </div>

                  <h2 class="mb-6 text-2xl md:text-3xl font-medium text-gradient font-heading">
                    {w.data.title}
                  </h2>

                  <p class="prose-p flex-1">{w.data.description}</p>

                  <div class="mt-6 mb-8">
                    <span class="text-5xl font-medium text-gradient">{w.data.price} zł</span>
                    <p class="mt-1 text-sm text-glass-muted">Cena za 1 osobę</p>
                  </div>

                  <ul class="space-y-2 mb-8">
                    <li class="flex items-center gap-2 text-glass-muted text-sm">
                      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-glass-accent-amber flex-shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      Czas trwania: {w.data.duration}
                    </li>
                    <li class="flex items-center gap-2 text-glass-muted text-sm">
                      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-glass-accent-amber flex-shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      Ważność: 12 miesięcy
                    </li>
                    <li class="flex items-center gap-2 text-glass-muted text-sm">
                      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-glass-accent-amber flex-shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      Natychmiastowa wysyłka e-mail
                    </li>
                  </ul>

                  {w.data.stripeUrl1 ? (
                    <a
                      href={w.data.stripeUrl1}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center justify-center w-full px-6 py-3 text-sm font-semibold text-glass-black bg-glass-white hover:bg-glass-white/90 rounded-full transition-all duration-200 hover:shadow-lg group"
                    >
                      Kup voucher
                      <svg class="ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </a>
                  ) : (
                    <a
                      href={`/contact`}
                      class="inline-flex items-center justify-center w-full px-6 py-3 text-sm font-semibold text-glass-white border border-glass-border hover:border-white/50 rounded-full transition-all duration-200"
                    >
                      Zapytaj o voucher
                    </a>
                  )}

                </div>
              </div>

              {/* Voucher 2 osoby — tylko jeśli hasPair */}
              {hasPair && (
                <div class="relative p-1 border border-glass-accent-amber/40 hover:border-glass-accent-amber/60 rounded-2xl transition-all duration-200 h-full">
                  <div class="absolute inset-0 bg-glass-accent-amber opacity-10 rounded-2xl blur-3xl pointer-events-none" aria-hidden="true"></div>
                  <div class="relative bg-gradient-to-t from-glass-anthracite to-glass-accent-amber/10 border border-white/10 rounded-xl px-8 lg:px-10 pb-10 pt-8 h-full flex flex-col">

                    <div class="mb-2 flex items-center gap-2">
                      <span class="badge badge-amber">2 osoby</span>
                      <span class="px-3 py-1 bg-glass-accent-amber text-glass-black text-xs font-semibold rounded-full">Oszczędzasz</span>
                    </div>

                    <h2 class="mb-6 text-2xl md:text-3xl font-medium text-gradient font-heading">
                      {w.data.title}
                    </h2>

                    <p class="prose-p flex-1">{w.data.description}</p>

                    <div class="mt-6 mb-8">
                      <span class="text-5xl font-medium text-gradient-amber">{w.data.pricePair} zł</span>
                      {w.data.pricePairLabel && (
                        <p class="mt-1 text-sm text-glass-accent-amber">{w.data.pricePairLabel}</p>
                      )}
                    </div>

                    <ul class="space-y-2 mb-8">
                      <li class="flex items-center gap-2 text-glass-muted text-sm">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-glass-accent-amber flex-shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Czas trwania: {w.data.duration}
                      </li>
                      <li class="flex items-center gap-2 text-glass-muted text-sm">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-glass-accent-amber flex-shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Ważność: 12 miesięcy
                      </li>
                      <li class="flex items-center gap-2 text-glass-muted text-sm">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-glass-accent-amber flex-shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Natychmiastowa wysyłka e-mail
                      </li>
                    </ul>

                    {w.data.stripeUrl2 ? (
                      <a
                        href={w.data.stripeUrl2}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-center w-full px-6 py-3 text-sm font-semibold text-glass-black bg-glass-accent-amber hover:bg-glass-accent-glow rounded-full transition-all duration-200 hover:shadow-lg group"
                      >
                        Kup voucher dla 2 osób
                        <svg class="ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                      </a>
                    ) : (
                      <a
                        href={`/contact`}
                        class="inline-flex items-center justify-center w-full px-6 py-3 text-sm font-semibold text-glass-white border border-glass-border hover:border-white/50 rounded-full transition-all duration-200"
                      >
                        Zapytaj o voucher
                      </a>
                    )}

                  </div>
                </div>
              )}
            </>
          );
        })}
      </div>
    </div>
  </section>

  {/* ── Sekcja 2 — FAQ ──────────────────────────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-4xl mx-auto">
        <h2 class="mb-16 text-center section-heading">Najczęściej zadawane pytania</h2>

        <div
          x-data={`{
            open: 0,
            faqs: ${JSON.stringify(faqs.map((f, i) => ({ i, question: f.data.question, answer: f.data.answer })))}
          }`}
        >
          <ul class="space-y-4">
            <template x-for="faq in faqs" x-bind:key="faq.i">
              <li class="p-1 border border-white/20 hover:border-white/30 rounded-2xl transition-all duration-200">
                <div
                  class="px-6 py-6 bg-gradient-to-t from-glass-anthracite to-glass-accent-fire/10 border border-white/10 rounded-xl"
                  x-data="{ isOpen: false }"
                >
                  <button
                    class="group w-full flex justify-between items-center text-left"
                    x-on:click="isOpen = !isOpen"
                    x-bind:aria-expanded="isOpen.toString()"
                  >
                    <h3 class="text-lg font-medium text-gradient font-heading pr-4" x-text="faq.question"></h3>
                    <span
                      class="flex-shrink-0 transform transition-transform duration-200"
                      x-bind:class="isOpen ? 'rotate-180' : 'rotate-0'"
                      aria-hidden="true"
                    >
                      <svg class="w-4 h-4 text-glass-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </span>
                  </button>

                  <div
                    x-show="isOpen"
                    x-transition:enter="transition ease-out duration-300"
                    x-transition:enter-start="opacity-0 -translate-y-2"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition ease-in duration-200"
                    x-transition:leave-start="opacity-100 translate-y-0"
                    x-transition:leave-end="opacity-0 -translate-y-2"
                  >
                    <p class="prose-p mt-4 max-w-2xl" x-text="faq.answer"></p>
                  </div>
                </div>
              </li>
            </template>
          </ul>
        </div>

        <p class="mt-12 text-center text-glass-muted">
          Nie ma odpowiedzi na Twoje pytanie?
          <a href="/contact" class="text-glass-accent-amber hover:text-glass-accent-glow transition-colors duration-200 ml-1">Napisz do nas →</a>
        </p>
      </div>
    </div>
  </section>

</BaseLayout>