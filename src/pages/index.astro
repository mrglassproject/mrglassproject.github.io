---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionProcess from '../components/ui/SectionProcess.astro';
import SectionWorkshop from '../components/ui/SectionWorkshop.astro';
import SectionBrands from '../components/ui/SectionBrands.astro';
import SectionCta from '../components/ui/SectionCta.astro';
import { cloudinaryUrl, cloudinarySrcset } from '../utils/cloudinary';
import { SITE } from '../config/site';

// Projekty do galerii — po 8 z każdej kategorii = 16 łącznie
const allProjects = await getCollection('projects');
const sorted = allProjects
  .filter(p => p.data.published !== false)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const firmaProjects = sorted
  .filter(p => p.data.category === 'dla-firm')
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);

const domProjects = sorted
  .filter(p => p.data.category === 'dla-domu')
  .sort(() => Math.random() - 0.5)
  .slice(0, 8);
const projects      = [...firmaProjects, ...domProjects];

const projectsData = projects.map(p => ({
  id:       p.id,
  title:    p.data.title,
  category: p.data.category,
  thumb:    cloudinaryUrl(p.data.images[0], { width: 600,  aspectRatio: '9:16', crop: 'fill' }),
  thumbSq:  cloudinaryUrl(p.data.images[0], { width: 600,  aspectRatio: '1:1',  crop: 'fill' }),
  full:     cloudinaryUrl(p.data.images[0], { width: 1400, crop: 'fill' }),
}));

// Zdjęcia sekcji narracyjnych
const FOTO_HERO  = 'maciej-rafalski-glass-project-warszawa-fot-home-hero-fot-0';
const FOTO_ABOUT = 'maciej-rafalski-glass-project-warszawa-fot-section-home-about-me';
const FOTO_PIEC  = 'maciej-rafalski-glass-project-warszawa-fot-home-piec-hutniczy-rozgrzany';

const b2bCards = [
  {
    title: 'Przestrzenie, które zostają w pamięci',
    desc:  'Szklane instalacje do lobby, recepcji i sal restauracyjnych. Obiekty, które definiują charakter miejsca — nie zdobią go, lecz go tworzą.',
  },
  {
    title: 'Detale architektoniczne wspomagające projekt',
    desc:  'Realizujemy elementy architektoniczne według dokumentacji projektowej. Panele, ścianki, detale fasad. Dostarczamy specyfikację techniczną.',
  },
  {
    title: 'Obiekty, które wzmacniają przekaz marki',
    desc:  'Nagrody, statuetki, obiekty okolicznościowe i limitowane edycje produktowe. Szkło jako nośnik tożsamości wizualnej.',
  },
];
---

<BaseLayout
  title={`${SITE.name} — Pracownia Szkła Artystycznego Warszawa`}
  description={SITE.description}
>

  {/* ── Sekcja 1 — Hero ─────────────────────────────────────────── */}
  <section class="section-py" id="hero">
    <div class="container px-4 mx-auto">
      <div class="flex flex-wrap items-center -mx-4">

        <div class="w-full lg:w-1/2 px-4 order-2 lg:order-1 mt-16 lg:mt-0">
          <p class="mb-6 text-sm font-medium tracking-widest uppercase text-glass-muted">
            Maciej Rafalski - Hutnik szkła - założyciel MR Glass Project
          </p>
          <h1 class="max-w-xl mb-8 text-4xl md:text-5xl lg:text-6xl font-medium text-glass-white font-heading leading-tight">
            Poznaj miejsce gdzie <span class="text-gradient-amber">ogień</span> staje się <span class="text-gradient-amber">formą</span>
          </h1>
          <p class="max-w-lg mb-10 prose-p">
            W mojej pracowni tworzę szkło użytkowe i dekoracyjne, łącząc techniki hutnicze z fusingiem. Realizuję projekty dla przestrzeni prywatnych i komercyjnych.
          </p>
          <a
            href="#home-1"
            class="inline-flex items-center justify-center px-8 py-4 text-sm font-semibold text-glass-black bg-glass-accent-amber hover:bg-glass-accent-glow rounded-full transition-all duration-200 hover:shadow-lg group"
          >
            <span>Zapraszam do pracowni</span>
            <svg class="ml-2 w-4 h-4 transform group-hover:translate-y-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </a>
        </div>

        <div class="w-full lg:w-1/2 px-4 order-1 lg:order-2 mb-16 lg:mb-0">
          <div class="relative">
            <div class="absolute inset-0 opacity-30 bg-gradient-to-r from-glass-accent-amber to-glass-accent-fire rounded-2xl blur-3xl" aria-hidden="true"></div>
            <div class="relative border border-glass-border rounded-2xl">
              <picture>
                <source
                  media="(max-width: 640px)"
                  srcset={cloudinarySrcset(FOTO_HERO, [400, 640], { aspectRatio: '1:1', crop: 'fill', gravity: 'face' })}
                  sizes="100vw"
                />
                <source
                  media="(min-width: 641px)"
                  srcset={cloudinarySrcset(FOTO_HERO, [400, 640, 720], { aspectRatio: '16:9', crop: 'fill', gravity: 'face' })}
                  sizes="50vw"
                />
                <img
                  src={cloudinaryUrl(FOTO_HERO, { width: 720, aspectRatio: '16:9', crop: 'fill', gravity: 'face' })}
                  alt="Maciej Rafalski — hutnik szkła, założyciel pracowni Glass Project Warszawa"
                  width="1280" height="720"
                  class="w-full h-auto object-cover rounded-xl"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </picture>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ── Sekcja 2 — O mnie ───────────────────────────────────────── */}
  <section class="section-py" id="home-1">
    <div class="container px-4 mx-auto">
      <div class="flex flex-wrap items-center -mx-4">

        <div class="w-full lg:w-1/2 px-4 mb-16 lg:mb-0">
          <div class="p-1 border border-glass-border rounded-2xl">
            <picture>
              <source
                media="(max-width: 640px)"
                srcset={cloudinarySrcset(FOTO_ABOUT, [400, 640], { aspectRatio: '1:1', crop: 'fill', gravity: 'face' })}
                sizes="100vw"
              />
              <source
                media="(min-width: 641px)"
                srcset={cloudinarySrcset(FOTO_ABOUT, [400, 640, 900], { aspectRatio: '4:3', crop: 'fill', gravity: 'face' })}
                sizes="50vw"
              />
              <img
                src={cloudinaryUrl(FOTO_ABOUT, { width: 900, aspectRatio: '4:3', crop: 'fill', gravity: 'face' })}
                alt="Maciej Rafalski przy pracy w pracowni szkła artystycznego"
                width="900" height="675"
                class="w-full h-auto object-cover rounded-xl"
                loading="lazy"
                decoding="async"
              />
            </picture>
          </div>
        </div>

        <div class="w-full lg:w-1/2 px-4">
          <div class="max-w-md lg:max-w-lg lg:mx-auto">
            <h2 class="mb-12 text-3xl md:text-4xl lg:text-5xl leading-tight font-medium text-gradient font-heading">
              Szkło rodzi się w ogniu, ruchu i czasie.<br/><br/>
              Ja próbuję zatrzymać tę chwilę w szkle.
            </h2>
            <a
              href="#home-2"
              class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-glass-black bg-glass-white hover:bg-glass-white/90 rounded-full transition-all duration-200 hover:shadow-lg group"
            >
              Jak rodzi się forma?
              <svg class="ml-2 w-4 h-4 transform group-hover:translate-y-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ── Sekcja 3 — Piec hutniczy ────────────────────────────────── */}
  <section class="section-py" id="home-2">
    <div class="container px-4 mx-auto">
      <div class="flex flex-wrap items-center -mx-4">

        <div class="w-full lg:w-1/2 px-4 mb-16 lg:mb-0 lg:order-last">
          <div class="p-1 border border-glass-border rounded-2xl">
            <picture>
              <source
                media="(max-width: 640px)"
                srcset={cloudinarySrcset(FOTO_PIEC, [400, 640], { aspectRatio: '4:3', crop: 'fill' })}
                sizes="100vw"
              />
              <source
                media="(min-width: 641px)"
                srcset={cloudinarySrcset(FOTO_PIEC, [400, 640, 900], { aspectRatio: '4:3', crop: 'fill' })}
                sizes="50vw"
              />
              <img
                src={cloudinaryUrl(FOTO_PIEC, { width: 900, aspectRatio: '4:3', crop: 'fill' })}
                alt="Piec hutniczy — pracownia Glass Project Warszawa"
                width="900" height="675"
                class="w-full h-auto object-cover rounded-xl"
                loading="lazy"
                decoding="async"
              />
            </picture>
          </div>
        </div>

        <div class="w-full lg:w-1/2 px-4">
          <div class="max-w-md lg:max-w-lg">
            <h2 class="section-heading">
              Tak to wszystko się zaczyna. W piecu hutniczym temperatura osiąga 1200°C.
            </h2>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* ── Sekcja 4 — Od ognia do formy ────────────────────────────── */}
  <SectionProcess />

  {/* ── Sekcja 5 — Przykładowe realizacje ──────────────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="section-heading">Przykładowe realizacje</h2>
      </div>

      <div
        x-data={`{
          tab: 'Wszystkie',
          lightbox: false,
          current: '',
          currentAlt: '',
          projects: ${JSON.stringify(projectsData)},
          get filtered() {
            if (this.tab === 'Wszystkie') return this.projects;
            const map = { 'Dla firm': 'dla-firm', 'Dla domu': 'dla-domu' };
            return this.projects.filter(p => p.category === map[this.tab]);
          },
          open(src, alt) { this.current = src; this.currentAlt = alt; this.lightbox = true; },
          close() { this.lightbox = false; }
        }`}
        x-on:keydown.escape.window="close()"
      >

        {/* Taby */}
        <div class="flex justify-center mb-12">
          <div class="inline-flex p-1 bg-glass-anthracite border border-glass-border rounded-full gap-1">
            {['Wszystkie', 'Dla firm', 'Dla domu'].map(label => (
              <button
                x-on:click={`tab = '${label}'`}
                x-bind:class={`tab === '${label}' ? 'bg-glass-white text-glass-black' : 'text-glass-muted hover:text-glass-white'`}
                class="px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200"
              >
                {label}
              </button>
            ))}
          </div>
        </div>

        {/* Siatka */}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          <template x-for="p in filtered" x-bind:key="p.id">
            <button
              class="group relative overflow-hidden rounded-xl border border-glass-border cursor-zoom-in"
              x-on:click="open(p.full, p.title)"
              x-bind:aria-label="`Powiększ: ${p.title}`"
            >
              <img
                x-bind:src="p.thumbSq"
                x-bind:alt="p.title"
                class="block md:hidden w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
              <img
                x-bind:src="p.thumb"
                x-bind:alt="p.title"
                class="hidden md:block w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-glass-black/0 group-hover:bg-glass-black/20 transition-colors duration-300 pointer-events-none"></div>
            </button>
          </template>
        </div>

        {/* Brak wyników */}
        <div x-show="filtered.length === 0" class="py-20 text-center text-glass-muted">
          Brak realizacji w tej kategorii.
        </div>

        {/* Link do wszystkich */}
        <div class="mt-16 text-center">
          <a
            href="/portfolio"
            class="inline-flex items-center justify-center px-8 py-4 text-sm font-semibold text-glass-white border border-glass-border hover:border-white/50 rounded-full transition-all duration-200 group"
          >
            <span>Zobacz wszystkie realizacje</span>
            <svg class="ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        {/* Lightbox */}
        <div
          x-show="lightbox"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="fixed inset-0 z-50 flex items-center justify-center bg-glass-black/95 p-4"
          x-on:click.self="close()"
          role="dialog"
          aria-modal="true"
        >
          <button class="absolute top-4 right-4 text-glass-muted hover:text-glass-white transition-colors duration-200" x-on:click="close()" aria-label="Zamknij">
            <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <img x-bind:src="current" x-bind:alt="currentAlt" class="max-w-full max-h-[90vh] rounded-xl object-contain"/>
        </div>

      </div>
    </div>
  </section>

  {/* ── Sekcja 6 — Brands ───────────────────────────────────────── */}
  <SectionBrands />

  {/* ── Sekcja 7 — Gdzie trafia nasze szkło (B2B) ──────────────── */}
  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-xl lg:max-w-3xl mx-auto text-center mb-16">
        <h2 class="section-heading">Gdzie trafia nasze szkło?</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {b2bCards.map(({ title, desc }) => (
          <div class="relative p-1 border border-white/20 rounded-2xl">
            <div class="absolute inset-0 bg-glass-accent-fire opacity-10 rounded-2xl blur-3xl pointer-events-none" aria-hidden="true"></div>
            <div class="bg-gradient-to-t from-glass-anthracite to-glass-accent-fire/10 border border-white/10 text-center p-8 pb-10 rounded-xl h-full">
              <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center rounded-full border border-glass-border text-glass-white">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/>
                </svg>
              </div>
              <h3 class="mb-3 text-xl md:text-2xl font-medium text-gradient font-heading">{title}</h3>
              <p class="text-glass-muted leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── Sekcja 8 — CTA B2B ──────────────────────────────────────── */}
  <SectionCta
    title="Realizujemy projekty dla firm, hoteli i architektów."
    description="Hotele, restauracje, biura, przestrzenie eventowe. Każda realizacja powstaje w pracowni od podstaw — ręcznie, według Twoich wymagań i w skali, której potrzebujesz."
    ctaLabel="Opisz nam swój projekt"
  />

  {/* ── Sekcja 9 — Warsztaty ────────────────────────────────────── */}
  <SectionWorkshop />

</BaseLayout>