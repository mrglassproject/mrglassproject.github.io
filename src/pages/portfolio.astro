---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionCta from '../components/ui/SectionCta.astro';
import { cloudinaryUrl } from '../utils/cloudinary';

const allProjects = await getCollection('projects');
const sorted = allProjects
  .filter(p => p.data.published !== false)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projects = sorted.map(p => {
  const images = p.data.images ?? [];
  const firstImage = images[0]?.image;

  return {
    id:          p.id,
    title:       p.data.title,
    description: p.data.description ?? null,
    dimensions:  p.data.dimensions ?? null,
    category:    p.data.category,

    thumb: firstImage
      ? cloudinaryUrl(firstImage, { width: 600, aspectRatio: '9:16', crop: 'fill' })
      : null,

    thumbSq: firstImage
      ? cloudinaryUrl(firstImage, { width: 600, aspectRatio: '1:1', crop: 'fill' })
      : null,

    images: images.map((item) =>
      cloudinaryUrl(item.image, { width: 1400, crop: 'fill' })
    ),

    imageAlts: images.map((item) => item.alt || p.data.title),
  };
});
---

<BaseLayout
  title="Realizacje — Glass Project Warszawa"
  description="Galeria szklanych obiektów artystycznych i użytkowych. Realizacje dla firm, hoteli, architektów i klientów prywatnych."
>

  <section class="section-py">
    <div class="container px-4 mx-auto">

      <div class="max-w-3xl mx-auto text-center mb-16">
        <h1 class="section-heading">Realizacje</h1>
        <p class="prose-p">
          Każdy obiekt powstaje ręcznie, w pracowni, w Warszawie na Ochocie.<br/>
          Poniżej wybrane prace z ostatnich lat.
        </p>
      </div>

      <div
        x-data={`{
          tab: 'Wszystkie',
          visible: 12,
          step: 8,

          // Lightbox
          lightbox: false,
          project: null,
          imgIndex: 0,

          projects: ${JSON.stringify(projects)},

          get filtered() {
            if (this.tab === 'Wszystkie') return this.projects;
            const map = { 'Dla firm': 'dla-firm', 'Dla domu': 'dla-domu' };
            return this.projects.filter(p => p.category === map[this.tab]);
          },
          get shown() {
            return this.filtered.slice(0, this.visible);
          },
          get hasMore() {
            return this.visible < this.filtered.length;
          },
          loadMore() {
            this.visible += this.step;
          },
          changeTab(name) {
            this.tab = name;
            this.visible = 12;
          },
          open(project, index = 0) {
            this.project = project;
            this.imgIndex = index;
            this.lightbox = true;
          },
          close() {
            this.lightbox = false;
            this.project = null;
          },
          prev() {
            if (this.project && this.imgIndex > 0) this.imgIndex--;
          },
          next() {
            if (this.project && this.imgIndex < this.project.images.length - 1) this.imgIndex++;
          }
        }`}
        x-on:keydown.escape.window="close()"
        x-on:keydown.arrow-left.window="prev()"
        x-on:keydown.arrow-right.window="next()"
      >

        {/* ── Taby ──────────────────────────────────────────────── */}
        <div class="flex justify-center mb-12">
          <div class="inline-flex p-1 bg-glass-anthracite border border-glass-border rounded-full gap-1">
            {['Wszystkie', 'Dla firm', 'Dla domu'].map(label => (
              <button
                x-on:click={`changeTab('${label}')`}
                x-bind:class={`tab === '${label}' ? 'bg-glass-white text-glass-black' : 'text-glass-muted hover:text-glass-white'`}
                class="px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200"
              >
                {label}
              </button>
            ))}
          </div>
        </div>

        {/* ── Siatka ────────────────────────────────────────────── */}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          <template x-for="p in shown" x-bind:key="p.id">
            <button
              class="group relative overflow-hidden rounded-xl border border-glass-border cursor-zoom-in text-left"
              x-on:click="open(p)"
              x-bind:aria-label="`Powiększ: ${p.title}`"
            >
              {/* Mobile — kwadrat */}
              <img
                x-bind:src="p.thumbSq"
                x-bind:alt="p.title"
                class="block md:hidden w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
              {/* Desktop — 9:16 */}
              <img
                x-bind:src="p.thumb"
                x-bind:alt="p.title"
                class="hidden md:block w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-glass-black/0 group-hover:bg-glass-black/30 transition-colors duration-300 pointer-events-none"></div>

              {/* Description pod zdjęciem */}
              <template x-if="p.description">
                <div class="p-3">
                  <p class="text-xs text-glass-muted leading-relaxed" x-text="p.description"></p>
                </div>
              </template>
            </button>
          </template>
        </div>

        {/* ── Załaduj więcej ────────────────────────────────────── */}
        <div x-show="hasMore" class="mt-12 text-center">
          <button
            x-on:click="loadMore()"
            class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-glass-white border border-glass-border hover:border-white/50 rounded-full transition-all duration-200"
          >
            Załaduj więcej prac
          </button>
        </div>

        {/* ── Brak wyników ──────────────────────────────────────── */}
        <div x-show="filtered.length === 0" class="py-20 text-center text-glass-muted">
          Brak realizacji w tej kategorii.
        </div>

        {/* ── Lightbox ──────────────────────────────────────────── */}
        <div
          x-show="lightbox"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-glass-black/95 p-4"
          x-on:click.self="close()"
          role="dialog"
          aria-modal="true"
        >
          {/* Zamknij */}
          <button
            class="absolute top-4 right-4 text-glass-muted hover:text-glass-white transition-colors duration-200"
            x-on:click="close()"
            aria-label="Zamknij"
          >
            <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>

          {/* Poprzednie */}
          <button
            x-show="project && imgIndex > 0"
            x-on:click="prev()"
            class="absolute left-4 top-1/2 -translate-y-1/2 text-glass-muted hover:text-glass-white transition-colors duration-200"
            aria-label="Poprzednie zdjęcie"
          >
            <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>

          {/* Zdjęcie */}
          <template x-if="project">
            <div class="flex flex-col items-center max-w-4xl w-full">
              <img
                x-bind:src="project.images[imgIndex]"
                x-bind:alt="project.title"
                class="max-h-[75vh] w-auto rounded-xl object-contain"
              />

              {/* Tytuł i opis */}
              <div class="mt-4 text-center px-4">
                <p class="text-glass-white font-medium" x-text="project.title"></p>
                <template x-if="project.description">
                  <p class="mt-1 text-sm text-glass-muted" x-text="project.description"></p>
                </template>
                <template x-if="project.dimensions">
                  <p class="mt-1 text-xs text-glass-smoke" x-text="project.dimensions"></p>
                </template>
              </div>

              {/* Dots nawigacja */}
              <template x-if="project.images.length > 1">
                <div class="flex gap-2 mt-4">
                  <template x-for="(img, i) in project.images" x-bind:key="i">
                    <button
                      x-on:click="imgIndex = i"
                      x-bind:class="imgIndex === i ? 'bg-glass-white' : 'bg-glass-border'"
                      class="w-2 h-2 rounded-full transition-colors duration-200"
                      x-bind:aria-label="`Zdjęcie ${i + 1}`"
                    ></button>
                  </template>
                </div>
              </template>
            </div>
          </template>

          {/* Następne */}
          <button
            x-show="project && imgIndex < project.images.length - 1"
            x-on:click="next()"
            class="absolute right-4 top-1/2 -translate-y-1/2 text-glass-muted hover:text-glass-white transition-colors duration-200"
            aria-label="Następne zdjęcie"
          >
            <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>

        </div>

      </div>
    </div>
  </section>

  <SectionCta
    title="Realizujemy projekty dla firm, hoteli i architektów"
    description="Hotele, restauracje, biura, przestrzenie eventowe. Każda realizacja powstaje w pracowni od podstaw - ręcznie, według Twoich wymagań i w skali, której potrzebujesz."
    ctaLabel="Opisz nam swój projekt"
  />

</BaseLayout>