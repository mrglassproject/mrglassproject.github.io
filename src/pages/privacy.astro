---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('pages');
const entry = entries.find(e => e.id === 'privacy');
const { Content } = await render(entry);
---

<BaseLayout
  title="Polityka prywatności — MR Glass Project"
  description="Polityka prywatności pracowni szkła artystycznego MR Glass Project Maciej Rafalski."
>

  <section class="section-py">
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto">

        <h1 class="section-heading">{entry.data.title}</h1>

        <p class="mb-8 text-sm text-glass-muted">
          Ostatnia aktualizacja: {entry.data.updatedAt.toLocaleDateString('pl-PL', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          })}
        </p>

        <div class="prose-content">
          <Content />
        </div>

      </div>
    </div>
  </section>

</BaseLayout>